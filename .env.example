# Angel One SmartAPI (free with demat account)
ANGEL_ONE_API_KEY=your_api_key_here
ANGEL_ONE_CLIENT_ID=your_client_id_here
ANGEL_ONE_PASSWORD=your_password_here
ANGEL_ONE_TOTP_SECRET=your_totp_secret_here

# FRED API (free, instant key at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Reddit API (free, create app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=AlphaCouncil/1.0

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Fyers API (optional, backup broker)
FYERS_APP_ID=
FYERS_SECRET_ID=

# System
LOG_LEVEL=INFO
AUTO_TUNE=false
INITIAL_CAPITAL=1000000
